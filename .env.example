# ──────────────────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────────────────
# These are used by the postgres service, plus by omniagent,
# dashboard, and backup via the compose env substitution.
POSTGRES_USER=omniagent
POSTGRES_PASSWORD=changeme
POSTGRES_DB=omniagent

# Alias used by dashboard and backup containers (expect PG* vars)
PGPASSWORD=${POSTGRES_PASSWORD}

DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
QDRANT_URL=http://qdrant:6333
HOST=0.0.0.0
PORT=8080

# ──────────────────────────────────────────────────────
# Agent / LLM configuration
# ──────────────────────────────────────────────────────
LLM_API_KEY=
LLM_PROVIDER=opencode-go
# Agent-level max tokens per response (read by agent/mod.rs)
MAX_TOKENS=8192
# LLM client-level max tokens (read by llm/mod.rs)
LLM_MAX_TOKENS=8192
TEMPERATURE=0.7
SUMMARIZE_AFTER_DAYS=7
MAX_ITERATIONS=60

# ──────────────────────────────────────────────────────
# Mattermost Platform — User Accounts & Setup
# ──────────────────────────────────────────────────────

# The mm-setup.py script uses MM_* vars (preferred) or falls back
# to legacy MATTERMOST_* vars for backward compatibility.

# Main user (MM_USERNAME replaces MATTERMOST_ADMIN_USER)
MM_USERNAME=lucasbasquerotto
MM_USER_PASSWORD=***
# MM_TEST_USERNAME / MM_TEST_PASSWORD: test user account
MM_TEST_USERNAME=testuser
MM_TEST_PASSWORD=***
# MM_BOT_USERNAME / MM_BOT_PASSWORD: bot user account
MM_BOT_USERNAME=omniagent
MM_BOT_PASSWORD=***
# MM_TEAM: team name to create. When set, creates the team and channel.
# The team name becomes the Mattermost team; the channel is created under it.
# If unset, no team or channel is created (only users are provisioned).
MM_TEAM=omni
# Channel to create under MM_TEAM (default: "setup")
MM_CHANNEL=setup
MATTERMOST_TEST_PASSWORD=TestPass123!

MATTERMOST_BOT_USER=omniagent
MATTERMOST_BOT_PASSWORD=BotPass123!

# Generated by the setup script — the bot's personal access token.
# The setup script creates this token after creating the bot user.
MATTERMOST_ACCESS_TOKEN=

# Bot username that the mattermost plugin uses to identify itself.
# Must match MATTERMOST_BOT_USER.
MATTERMOST_BOT_USERNAME=${MATTERMOST_BOT_USER}

# Comma-separated channel IDs to watch. Auto-populated by setup script.
MATTERMOST_CHANNEL_IDS=

# Connection mode: polling or websocket
MATTERMOST_CONNECTION_MODE=websocket

# Set to true if using polling mode
MATTERMOST_POLLING_ENABLED=false
MATTERMOST_POLLING_INTERVAL=15

MATTERMOST_SERVER_URL=http://omm-mattermost:8065
MATTERMOST_SITE_URL=https://hermes-app-5.nexuslbs.org
