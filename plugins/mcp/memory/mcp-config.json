{
  "servers": [
    {
      "name": "memory",
      "transport": "stdio",
      "command": "/app/target/release/mcp-server-memory",
      "args": [],
      "timeout_secs": 60,
      "max_retries": 2,
      "allowed_tools": [
        "*"
      ],
      "env": {
        "DATABASE_URL": "${DATABASE_URL}",
        "OMNI_DATA_DIR": "${OMNI_DATA_DIR:-/opt/data}",
        "RUST_LOG": "info"
      }
    }
  ]
}