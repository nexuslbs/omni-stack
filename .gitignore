# omni-stack .gitignore
# Allow everything by default — only exclude build artifacts, env files, and secrets.

# ── Build artifacts ──
target/
node_modules/
dist/

# ── Environment / secrets ──
.env
.env.backup
.env.bak
.env.*.local
backup.env
credentials/

# ── Temporary / generated files ──
COMMIT_MSG.txt
create-wiki-task.json
ready-wiki-task.json
*.bak
scripts/
docs/
notes/

# ── OS files ──
.DS_Store
Thumbs.db

# ── Runtime-only: temp, logs ──
*.log
tmp/
profiles/default/tmp/
hindsight_watermark.json

# ── Eliminated struct — workspace root, each plugin has own Cargo.toml ──
/Cargo.toml

# ── Dashboard build output (copied into plugins/ by build process) ──
plugins/assets/
plugins/favicon.svg
plugins/index.html

vectorizer-state.json
