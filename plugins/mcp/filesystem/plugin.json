{
  "id": "mcp-server-filesystem",
  "name": "Filesystem MCP Server",
  "version": "0.1.0",
  "description": "Filesystem tools — read, write, list, search, info on local files",
  "type": "mcp",
  "entrypoint": "mcp-server-filesystem",
  "config_schema": [
    {
      "key": "OMNI_DATA_DIR",
      "label": "Data Directory",
      "type": "string",
      "default": "/opt/data",
      "description": "Allowed data directory (for path validation)"
    },
    {
      "key": "WORKSPACE_DIR",
      "label": "Workspace Directory",
      "type": "string",
      "default": "/opt/workspace",
      "description": "Allowed workspace directory (for path validation)"
    }
  ]
}
