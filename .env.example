# ════════════════════════════════════════════
# Omni‑Stack — Minimal .env Template
# ════════════════════════════════════════════
#
# Only POSTGRES_PASSWORD and COMPOSE_PROFILES are
# mandatory.  Everything else is optional (leave
# commented out to use the docker-compose default).


# ── Always required ─────────────────────────

COMPOSE_PROFILES=                # e.g. "memory,tunnel" or "mattermost,memory"
POSTGRES_PASSWORD=               # single truly-required secret


# ── S3 (backup / restore / checkpoint) ──────
# Only needed if you enable backup or checkpoint
# cron schedules in docker-compose.yml.

# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT=
# S3_REGION=
# S3_BUCKET=
# S3_PATH=                        # object prefix within the bucket (default: omni)
# BACKUP_CRON_SCHEDULE=            # periodic backup to S3 (crontab), e.g. "0 3 * * *"
# CHECKOUT_CRON_SCHEDULE=         # periodic checkpoint to S3 (crontab), each run→separate YYYYMMDD prefix


# ── Cloudflare Tunnel ───────────────────────
# Only needed with profile "tunnel" or "all".

# TUNNEL_TOKEN=


# ── Mattermost ──────────────────────────────
# Only needed with profile "mattermost" or "all".
# MM_SITEURL is optional — Mattermost auto-
# detects from the first HTTP request if empty.

# MM_POSTGRES_PASSWORD=
# MM_SITEURL=


# ── Optionals (sensible defaults) ───────────
# All image vars below have defaults in docker-
# compose.yml.  Override only to pin a version.

# EXPLORER_DIR=                   # dashboard file-explorer root (default: /opt)

# POSTGRES_IMAGE=                 # default: pgvector/pgvector:pg16
# OMNIAGENT_IMAGE=                # default: omniagent-dev:latest (local build)
# DASHBOARD_IMAGE=                # default: ghcr.io/nexuslbs/omni-dashboard:latest
# TOOLBOX_IMAGE=                  # default: ghcr.io/nexuslbs/omni-stack-toolbox:latest
# CLOUDFLARED_IMAGE=              # default: cloudflare/cloudflared:2026.7.1
# MATTERMOST_DB_IMAGE=            # default: postgres:16.14
# MATTERMOST_IMAGE=               # default: mattermost/mattermost-team-edition:10.11.20
# QDRANT_IMAGE=                   # default: qdrant/qdrant:v1.18.2
# HINDSIGHT_IMAGE=                # default: ghcr.io/vectorize-io/hindsight:0.7.2
# CADVISOR_IMAGE=                 # default: ghcr.io/google/cadvisor:v0.57.0
# PROMETHEUS_IMAGE=               # default: prom/prometheus:v3.5.5
# VECTOR_IMAGE=                   # default: timberio/vector:0.55.0-debian
# LOKI_IMAGE=                     # default: grafana/loki:3.7.2
# GRAFANA_IMAGE=                  # default: grafana/grafana:13.0.1
# OMNI_DIR=                       # Hermes shared data root (default: /opt/omni)
