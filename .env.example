# ──────────────────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────────────────
# These are used by the postgres service, plus by omniagent,
# dashboard, and backup via the compose env substitution.
POSTGRES_USER=omniagent
POSTGRES_PASSWORD=changeme
POSTGRES_DB=omniagent

# Alias used by dashboard and backup containers (expect PG* vars)
PGPASSWORD=${POSTGRES_PASSWORD}

DATABASE_URL=postgres://${POSTGRES_USER}:***@postgres:5432/${POSTGRES_DB}
QDRANT_URL=http://qdrant:6333
HOST=0.0.0.0
PORT=8080

# ──────────────────────────────────────────────────────
# Agent / LLM configuration
LLM_PROVIDER=opencode-go
# Agent-level max tokens per response (read by agent/mod.rs)
MAX_TOKENS=8192
# LLM client-level max tokens (read by llm/mod.rs)
LLM_MAX_TOKENS=8192
TEMPERATURE=0.7
SUMMARIZE_AFTER_DAYS=7
MAX_ITERATIONS=60

# ──────────────────────────────────────────────────────
# Mattermost Platform : User Accounts & Setup
# ──────────────────────────────────────────────────────
# These env vars are referenced by platforms.yml via $env: prefix.
# Set them here (or in your deployment .env) : they never go into
# platforms.yml itself, keeping it environment-agnostic.

# Main user (admin account created during setup)
MM_USERNAME=lucasbasquerotto
MM_USER_PASSWORD=***
# Test user account
MM_TEST_USERNAME=testuser
MM_TEST_PASSWORD=***
# Bot user account
MM_BOT_USERNAME=omniagent
# Team name to create during setup. Creates team + channel under it.
MM_TEAM=omni
# Channel to create under MM_TEAM (default: "setup")
# The setup creates the omniagent channel as mm-{MM_CHANNEL}
MM_CHANNEL=setup

# Mattermost server URL (internal Docker network)
MATTERMOST_SERVER_URL=http://mattermost:8065

# Bot's personal access token : generated during setup.
# After running POST /api/plugins/mattermost/setup, set this to the
# returned bot_token value.
MATTERMOST_ACCESS_TOKEN=

# Bot username that the mattermost plugin uses to identify itself.
# Must match MM_BOT_USERNAME.
MATTERMOST_BOT_USERNAME=${MM_BOT_USERNAME}

# Connection mode: polling or websocket
MATTERMOST_CONNECTION_MODE=websocket

# Polling interval (only used in polling mode)
MATTERMOST_POLLING_INTERVAL=15

MATTERMOST_SITE_URL=https://hermes-app-5.nexuslbs.org

# ── Backup cron schedule ──────────────────────────────────────────
# BACKUP_CRON_SCHEDULE and CHECKOUT_CRON_SCHEDULE set backup/checkout
# frequency in standard crontab format. Leave empty for no automatic backup.
# BACKUP_CRON_SCHEDULE="0 3 * * *"   # Daily at 3am
# CHECKOUT_CRON_SCHEDULE="0 3 * * 0"  # Weekly on Sunday at 3am
BACKUP_CRON_SCHEDULE=
CHECKOUT_CRON_SCHEDULE=


# Backup cron schedule (crontab format, empty = no automatic backup)
# BACKUP_CRON_SCHEDULE="0 3 * * *"   # Daily at 3am
# CHECKOUT_CRON_SCHEDULE="0 3 * * 0"  # Weekly on Sunday at 3am
BACKUP_CRON_SCHEDULE=
CHECKOUT_CRON_SCHEDULE=
