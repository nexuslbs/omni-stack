# omni-stack .gitignore
# Allow everything by default — only exclude build artifacts, env files, and secrets.

# ── Build artifacts ──
target/
node_modules/
dist/

# ── Environment / secrets ──
.env
.env.*.local
.env.bak
.env.cron

# ── Temporary / generated files ──
COMMIT_MSG.txt

# ── Git plugin cache (shared bare mirrors for remote plugin clones) ──
.git-cache/
*.bak
scripts/__pycache__/
docs/
notes/

# ── Runtime test artifacts (created by tests.py) ──
plugins/tools/test-python-tool/

# ── OS files ──
.DS_Store
Thumbs.db

# ── Runtime-only: temp, logs ──
*.log
tmp/
profiles/default/tmp/

# ── Eliminated struct — workspace root, each plugin has own Cargo.toml ──
/Cargo.toml

/data/
# ── Auto-generated remote plugin clones (ignored per type dir) ──
plugins/platforms/.remote/
plugins/tools/.remote/
plugins/providers/.remote/

# ── Python bytecode cache ──
__pycache__/
*.pyc
