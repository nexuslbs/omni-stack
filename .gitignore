# omni-stack .gitignore
# Allow everything by default — only exclude build artifacts, env files, and secrets.

# ── Build artifacts ──
target/
node_modules/
dist/

# ── Environment / secrets ──
.env
credentials/

# ── OS files ──
.DS_Store
Thumbs.db

# ── Runtime-only: temp, logs ──
*.log
tmp/
profiles/default/tmp/
hindsight_watermark.json

# ── Eliminated struct — workspace root, each plugin has own Cargo.toml ──
/Cargo.toml
